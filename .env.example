# ---------------------------------------------------------------------------
# Example environment configuration. Copy to `.env` and adjust.
# NEVER commit a real .env with secrets. All values below are safe defaults
# or placeholders.
# ---------------------------------------------------------------------------

# --- Application ---
APP_NAME="Dynamic Pricing System"
ENVIRONMENT=local            # local | development | staging | production | test
DEBUG=false

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
# Set a strong key in non-local environments. When left at this default and
# ENVIRONMENT is not "production", API-key auth is bypassed for convenience.
API_KEY=change-me-in-production
# Comma-separated list of allowed CORS origins, or * for all.
CORS_ALLOW_ORIGINS=*

# --- Logging ---
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false               # true to emit structured JSON logs

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=pricing
POSTGRES_PASSWORD=pricing
POSTGRES_DB=pricing
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL_SECONDS=3600

# --- Anthropic / LLM (optional; used only for cleaning & explanations) ---
# Leave ANTHROPIC_API_KEY empty to run fully offline (rule-based fallbacks).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TEMPERATURE=0.0
LLM_ENABLED=true

# --- MLflow (optional) ---
MLFLOW_TRACKING_URI=file:./data/models/mlruns
MLFLOW_EXPERIMENT=dynamic-pricing

# --- Paths (defaults are under ./data) ---
# MODEL_DIR=./data/models
# FEATURE_STORE_DIR=./data/features
# RAW_DATA_DIR=./data/raw
# PROCESSED_DATA_DIR=./data/processed

# --- Training ---
OPTUNA_TRIALS=40
CV_SPLITS=4
RANDOM_SEED=42

# --- Scraping ---
SCRAPE_TARGETS_FILE=app/scraping/targets.yaml
SCRAPE_MAX_CONCURRENCY=4
SCRAPE_REQUEST_DELAY_SECONDS=1.5
SCRAPE_TIMEOUT_SECONDS=30.0
SCRAPE_MAX_RETRIES=3
SCRAPE_RESPECT_ROBOTS=true
